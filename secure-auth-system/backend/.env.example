# ====================================================
# Secure Authentication System — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to version control.
# ====================================================

# --- Server ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=secure_auth_system

# --- JWT ---
# Generate a strong random secret, e.g. with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=30m

# --- Session / Lockout policy ---
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
SESSION_DURATION_MINUTES=30
OTP_EXPIRY_MINUTES=10

# --- SMTP (Email OTP) ---
# Add real credentials when ready. Until then, OTP emails will fail gracefully
# and the OTP will also be logged to the server console in development mode
# so you can still test the flow without a working mailbox.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Secure Auth System
SMTP_FROM_EMAIL=no-reply@secureauth.com

# --- Google Gemini AI API ---
# Get a key from https://aistudio.google.com/app/apikey — leave blank to run with
# AI features gracefully disabled (a clear fallback message is returned instead).
GEMINI_API_KEY=

# --- Initial Admin (used only by the create-admin script) ---
ADMIN_FULL_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
